---
import Landing from "../layouts/Landing.astro";
import TransformHero from "../components/TransformHero.astro";
import FeatureCard from "../components/FeatureCard.astro";
import InstallBlock from "../components/InstallBlock.astro";
import ThemeShowcase from "../components/ThemeShowcase.astro";
import SafetyLevels from "../components/SafetyLevels.astro";
import TerminalWindow from "../components/TerminalWindow.astro";
import SectionHeader from "../components/SectionHeader.astro";
---

<Landing title="Magic Shell - Natural Language to Terminal Commands">
  <TransformHero />

  <!-- Features Section -->
  <section class="section features" id="features">
    <div class="container">
      <SectionHeader
        eyebrow="01 — Capabilities"
        title="Magic Shell 1.0 is here"
        subtitle="Unified palettes, slash commands, explicit safety, and faster model switching—so you stop memorizing flags and just type."
      />

      <div class="features-grid">
        <FeatureCard
          title="Natural Language"
          description="Describe what you want in plain English. Get the right command for your shell—no man-page digging required."
          icon="language"
          accent="primary"
          featured
          reveal
        />
        <FeatureCard
          title="Safety Analysis"
          description="Every command is checked for risk before it runs. Destructive patterns are blocked automatically—so a typo won't cost you."
          icon="shield"
          accent="danger"
          featured
          reveal
        />
        <FeatureCard
          title="Multiple AI Providers"
          description="Pick from OpenCode Zen, OpenRouter, Vercel and Cloudflare gateways, Workers AI, or your own local models. Free options on every provider."
          icon="providers"
          accent="secondary"
          reveal
        />
        <FeatureCard
          title="Unified Palettes"
          description="Commands, slash actions, models, providers, themes, safety, and thinking levels share one picker. Learn it once, use it everywhere."
          icon="palette"
          accent="accent"
          reveal
        />
        <FeatureCard
          title="Slash Commands"
          description="Type / to discover actions. /models, /providers, /themes, /safety, and /thinking open the same pickers as the keyboard shortcuts—no menus to hunt."
          icon="slash"
          accent="info"
          reveal
        />
        <FeatureCard
          title="Project Aware"
          description="Opt-in context detection reads your package.json scripts, Makefile targets, and more. Say 'run dev'—it already knows what to do."
          icon="folder"
          accent="warning"
          reveal
        />
        <FeatureCard
          title="Shell-Aware"
          description="Detects bash, zsh, fish, PowerShell, and more automatically. Every command adapts to your shell's syntax—no guesswork."
          icon="terminal"
          accent="primary"
          reveal
        />
        <FeatureCard
          title="Auto Updates"
          description="Checks for new versions on startup and can install them for you. Stay current without thinking about it."
          icon="refresh"
          accent="secondary"
          reveal
        />
      </div>
    </div>
  </section>

  <!-- Two Ways to Use -->
  <section class="section two-modes" id="modes">
    <div class="container">
      <SectionHeader
        eyebrow="02 — Two modes"
        title="Two ways to use"
        subtitle="A full TUI when you want it, a one-liner when you don't."
      />

      <div class="modes-grid">
        <!-- TUI Mode -->
        <div class="mode-card">
          <div class="mode-header">
            <span class="mode-icon">[]</span>
            <h3>Interactive TUI</h3>
            <span class="mode-badge">Recommended</span>
          </div>
          <p class="mode-description">
            A full terminal interface with unified command palettes, slash commands, themes,
            history, model switching, and safety analysis.
          </p>
          <TerminalWindow title="launch">
            <code class="step-code"><span class="prompt">$</span> mshell</code>
          </TerminalWindow>
          <ul class="mode-features">
            <li>8 beautiful themes</li>
            <li>Command history</li>
            <li>Switch models and providers on the fly</li>
            <li>Slash commands and keyboard shortcuts</li>
          </ul>
        </div>

        <!-- CLI Mode -->
        <div class="mode-card">
          <div class="mode-header">
            <span class="mode-icon">$_</span>
            <h3>Quick CLI</h3>
          </div>
          <p class="mode-description">
            One-shot commands for fast translations. Pipe output, use in scripts,
            or execute directly with <code>-x</code>.
          </p>
          <TerminalWindow title="examples">
            <code class="step-code"><span class="prompt">$</span> msh "find large files"</code>
            <code class="step-code"><span class="output-text">find . -type f -size +100M</span></code>
            <code class="step-code" style="margin-top: 8px;"><span class="prompt">$</span> msh -x "show disk usage"</code>
          </TerminalWindow>
          <ul class="mode-features">
            <li>Quick one-liners</li>
            <li>Pipe to clipboard</li>
            <li>Script-friendly</li>
            <li>Dry-run with <code>-n</code></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Safety Section -->
  <section class="section safety" id="safety">
    <div class="container">
      <SectionHeader
        eyebrow="03 — Safety"
        title="Built-in safety"
        subtitle="Every command is checked before it runs. The dangerous ones never reach your shell."
      />

      <div class="safety-content">
        <SafetyLevels />
      </div>
    </div>
  </section>

  <!-- Themes Section -->
  <section class="section themes" id="themes">
    <div class="container">
      <SectionHeader
        eyebrow="04 — Themes"
        title="8 beautiful themes"
        subtitle="Match your terminal aesthetic. Switch live with <code>Ctrl+X T</code> or <code>/themes</code>."
      />

      <ThemeShowcase />
    </div>
  </section>

  <!-- Get Started Section -->
  <section class="section install" id="get-started">
    <div class="container">
      <SectionHeader
        eyebrow="05 — Get started"
        title="Get started in seconds"
        subtitle="One command to install—free models to start. Works on macOS, Linux, and Windows."
      />

      <div class="get-started-flow">
        <ol class="steps">
          <li class="step reveal" style="--reveal-i: 0">
            <div class="step-number">1</div>
            <div class="step-body">
              <div class="step-label">Install</div>
              <div class="install-wrapper"><InstallBlock platform="bun" /></div>
            </div>
          </li>
          <li class="step reveal" style="--reveal-i: 1">
            <div class="step-number">2</div>
            <div class="step-body">
              <div class="step-label">Configure your API key</div>
              <TerminalWindow title="setup">
                <code class="step-code"><span class="prompt">$</span> msh --setup</code>
              </TerminalWindow>
            </div>
          </li>
          <li class="step reveal" style="--reveal-i: 2">
            <div class="step-number">3</div>
            <div class="step-body">
              <div class="step-label">Launch the TUI</div>
              <TerminalWindow title="launch">
                <code class="step-code"><span class="prompt">$</span> mshell</code>
              </TerminalWindow>
            </div>
          </li>
        </ol>

        <div class="final-cta">
          <a href="/getting-started/installation/" class="btn btn-primary-cta">
            Read the docs
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="https://github.com/designxdevelop/magic-shell" class="btn btn-secondary-cta" target="_blank" rel="noopener">
            Star on GitHub
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-brand">
          <span class="footer-logo">$ msh</span>
          <p class="footer-tagline">Type what you mean. Execute what you need.</p>
          <p class="footer-version">Magic Shell · v1.0 · MIT License</p>
        </div>

        <div class="footer-columns">
          <div class="footer-col">
            <h4 class="footer-heading">Docs</h4>
            <a href="/getting-started/installation/" class="footer-link">Installation</a>
            <a href="/getting-started/configuration/" class="footer-link">Configuration</a>
            <a href="/getting-started/first-command/" class="footer-link">First Command</a>
            <a href="/reference/cli-options/" class="footer-link">CLI Options</a>
          </div>
          <div class="footer-col">
            <h4 class="footer-heading">Features</h4>
            <a href="/features/providers/" class="footer-link">AI Providers</a>
            <a href="/features/safety-levels/" class="footer-link">Safety Levels</a>
            <a href="/features/themes/" class="footer-link">Themes</a>
            <a href="/features/tui-mode/" class="footer-link">TUI Mode</a>
          </div>
          <div class="footer-col">
            <h4 class="footer-heading">Community</h4>
            <a href="https://github.com/designxdevelop/magic-shell" class="footer-link" target="_blank" rel="noopener">GitHub</a>
            <a href="https://github.com/designxdevelop/magic-shell/issues" class="footer-link" target="_blank" rel="noopener">Issues</a>
            <a href="/reference/changelog/" class="footer-link">Changelog</a>
          </div>
        </div>
      </div>

      <div class="footer-bottom">
        <p>
          Created by <a href="https://github.com/austin-thesing" target="_blank" rel="noopener">Austin Thesing</a>
        </p>
        <p class="footer-agency">
          A <a href="https://designxdevelop.com" target="_blank" rel="noopener">Design X Develop LLC</a> project
        </p>
      </div>
    </div>
  </footer>
</Landing>

<style>
  /* Section styling */
  .section {
    padding: var(--space-24) 0;
    position: relative;
    scroll-margin-top: 72px;
  }

  .section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: min(900px, 80%);
    height: 1px;
    background: var(--divider-color);
  }

  .section:first-of-type::before {
    display: none;
  }

  /* Features - bento grid */
  .features {
    background: linear-gradient(180deg, var(--bg-void) 0%, var(--bg-base) 100%);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-5);
  }

  .features-grid :global(.feature-card) {
    grid-column: span 2;
  }

  .features-grid :global(.feature-card.featured) {
    grid-column: span 3;
  }

  .features-grid :global(.feature-card:nth-child(1)) { --reveal-i: 0; }
  .features-grid :global(.feature-card:nth-child(2)) { --reveal-i: 1; }
  .features-grid :global(.feature-card:nth-child(3)) { --reveal-i: 2; }
  .features-grid :global(.feature-card:nth-child(4)) { --reveal-i: 3; }
  .features-grid :global(.feature-card:nth-child(5)) { --reveal-i: 3; }
  .features-grid :global(.feature-card:nth-child(6)) { --reveal-i: 4; }
  .features-grid :global(.feature-card:nth-child(7)) { --reveal-i: 4; }
  .features-grid :global(.feature-card:nth-child(8)) { --reveal-i: 5; }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .features-grid :global(.feature-card),
    .features-grid :global(.feature-card.featured) {
      grid-column: span 1;
    }
  }

  @media (max-width: 560px) {
    .features-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Two Modes */
  .two-modes {
    background: var(--bg-base);
  }

  .modes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .modes-grid {
      grid-template-columns: 1fr;
    }
  }

  .mode-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: all var(--transition-fast);
  }

  .mode-card:hover {
    border-color: var(--border-active);
    transform: translateY(-2px);
  }

  .mode-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .mode-icon {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-primary);
    background: var(--bg-terminal);
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
  }

  .mode-header h3 {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--text-primary);
    margin: 0;
  }

  .mode-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-secondary);
    background: rgba(92, 156, 245, 0.1);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(92, 156, 245, 0.2);
  }

  .mode-description {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .mode-description code {
    background: var(--bg-terminal);
    padding: 0.1em 0.3em;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }

  .mode-features {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
  }

  .mode-features li {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .mode-features li::before {
    content: ">";
    color: var(--color-primary);
    font-weight: 600;
  }

  .mode-features li code {
    background: var(--bg-terminal);
    padding: 0.1em 0.3em;
    border-radius: var(--radius-sm);
  }

  .step-code {
    display: block;
    font-size: var(--text-sm);
    background: none;
    padding: 0;
  }

  .step-code .prompt {
    color: var(--color-primary);
    margin-right: var(--space-2);
  }

  .step-code .output-text {
    color: var(--text-secondary);
  }

  /* Safety */
  .safety {
    background: linear-gradient(180deg, var(--bg-base) 0%, var(--bg-void) 100%);
  }

  .safety-content {
    max-width: 600px;
    margin: 0 auto;
  }

  /* Themes */
  .themes {
    background: var(--bg-void);
  }

  /* Get Started */
  .install {
    background: var(--bg-base);
    padding-bottom: var(--space-16);
  }

  .get-started-flow {
    max-width: 720px;
    margin: 0 auto;
  }

  .steps {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-10) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .step {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .step-number {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 25%, transparent);
    border-radius: 50%;
  }

  .step-body {
    flex: 1;
    min-width: 0;
  }

  .step-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-2);
  }

  .step .install-wrapper {
    max-width: 100%;
  }

  .final-cta {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: all 0.2s ease;
    text-decoration: none;
  }

  .btn-primary-cta {
    background: var(--color-primary);
    color: var(--bg-void);
  }

  .btn-primary-cta:hover {
    background: var(--color-primary-dim);
    color: var(--bg-void);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px var(--color-primary-glow);
  }

  .btn-secondary-cta {
    background: var(--bg-elevated);
    color: var(--text-primary);
    border: 1px solid var(--border-subtle);
  }

  .btn-secondary-cta:hover {
    border-color: var(--border-active);
    color: var(--text-primary);
    transform: translateY(-1px);
  }

  /* Footer */
  .footer {
    background: var(--bg-terminal);
    border-top: 1px solid var(--border-subtle);
    padding: var(--space-16) 0 var(--space-8);
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--space-12);
    margin-bottom: var(--space-8);
  }

  .footer-brand {
    max-width: 280px;
  }

  .footer-logo {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-primary);
  }

  .footer-tagline {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    margin-top: var(--space-3);
  }

  .footer-version {
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    margin-top: var(--space-2);
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .footer-heading {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: var(--space-3);
    font-weight: 600;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .footer-bottom {
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-subtle);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    align-items: center;
  }

  .footer-bottom p {
    color: var(--text-muted);
    font-size: var(--text-xs);
  }

  .footer-agency {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 2px var(--space-2);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg-terminal) 60%, transparent);
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .footer-agency a {
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .footer-agency a:hover {
    color: var(--color-primary);
  }

  .footer-bottom a {
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .footer-bottom a:hover {
    color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .footer-columns {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .footer-columns {
      grid-template-columns: 1fr;
    }

    .final-cta .btn {
      width: 100%;
      max-width: 320px;
      justify-content: center;
    }
  }
</style>
