---
import DefaultHead from "@astrojs/starlight/components/Head.astro"
import Schema from "./Schema.astro"

const { entry } = Astro.locals.starlightRoute
const { title, description } = entry.data
---

<DefaultHead />
<Schema
  type="article"
  title={title}
  description={description}
  url={Astro.url.href}
/>
